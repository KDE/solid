#: tools/solid-hardware/solid-hardware.cpp:218
#: tools/solid-hardware/solid-hardware.cpp:341
msgctxt "solid-hardware|"
msgid "Device udi"
msgstr "udi на устройство"

#: tools/solid-hardware/solid-hardware.cpp:230
msgctxt "solid-hardware|"
msgid "Syntax:"
msgstr "Синтаксис:"

#: tools/solid-hardware/solid-hardware.cpp:233
msgctxt "solid-hardware|"
msgid ""
"             # List the hardware available in the system.\n"
"             # - If the 'nonportableinfo' option is specified, the device\n"
"             # properties are listed (be careful, in this case property "
"names\n"
"             # are backend dependent),\n"
"             # - If the 'details' option is specified, the device "
"interfaces\n"
"             # and the corresponding properties are listed in a platform\n"
"             # neutral fashion,\n"
"             # - Otherwise only device UDIs are listed.\n"
msgstr ""
"            # Списък на хардуера, наличен в системата. \n"
"            # - Ако е посочена опцията \"nonportableinfo\", свойствата на  \n"
"            #устройството са изброени  (бъдете внимателни, в този случай "
"имената \n"
"            #на свойствата са зависими от бекенда), \n"
"            # - Ако е посочена опцията \"details\", интерфейсите на "
"устройството\n"
"            # и съответните свойства са изброени в платформено \n"
"            # неутрален начин.\n"
"            # - В противен случай са изброени само  UDI на устройството. \n"

#: tools/solid-hardware/solid-hardware.cpp:245
msgctxt "solid-hardware|"
msgid ""
"             # Display all the interfaces and properties of the device\n"
"             # corresponding to 'udi' in a platform neutral fashion.\n"
msgstr ""
"            # Показване на всички интерфейси и свойства на устройството \n"
"            # съответстващо на 'udi' по независим от платформата начин. \n"

#: tools/solid-hardware/solid-hardware.cpp:251
msgctxt "solid-hardware|"
msgid ""
"             # Display all the properties of the device corresponding to "
"'udi'\n"
"             # (be careful, in this case property names are backend "
"dependent).\n"
msgstr ""
"            # Показване на всички свойства на устройството, съответстващи на "
"'udi'\n"
"            # (бъдете внимателни, в този случай имената на свойствата са "
"бекенд зависими).​​\n"

#: tools/solid-hardware/solid-hardware.cpp:257
msgctxt "solid-hardware|"
msgid ""
"             # List the UDI of devices corresponding to 'predicate'.\n"
"             # - If 'parentUdi' is specified, the search is restricted to "
"the\n"
"             # branch of the corresponding device,\n"
"             # - Otherwise the search is done on all the devices.\n"
msgstr ""
"             # Списък на UDI на устройства, съответстващи на \"predicate"
"\". \n"
"             # - Ако е посочен 'parentUdi', търсенето е ограничено до\n"
"             # вида на съответното устройство, \n"
"             # - В противен случай търсенето се извършва на всички "
"устройства. \n"

#: tools/solid-hardware/solid-hardware.cpp:265
msgctxt "solid-hardware|"
msgid ""
"             # If applicable, mount the device corresponding to 'udi'.\n"
msgstr ""
"             # Ако е възможно, устройството се монтира в съответствие на "
"'udi'. \n"

#: tools/solid-hardware/solid-hardware.cpp:268
msgctxt "solid-hardware|"
msgid ""
"             # If applicable, unmount the device corresponding to 'udi'.\n"
msgstr ""
"             # Ако е възможно, устройството се демонтира в съответствие на "
"'udi'. \n"

#: tools/solid-hardware/solid-hardware.cpp:271
msgctxt "solid-hardware|"
msgid ""
"             # If applicable, eject the device corresponding to 'udi'.\n"
msgstr ""
"             # Ако е възможно, устройството се изважда в съответствие на "
"'udi'. \n"

#: tools/solid-hardware/solid-hardware.cpp:274
msgctxt "solid-hardware|"
msgid "             # Listen to all add/remove events on supported hardware.\n"
msgstr ""
"             # Следене на всички събития за добавяне/премахване на поддържан "
"хардуер.\n"

#: tools/solid-hardware/solid-hardware.cpp:277
msgctxt "solid-hardware|"
msgid "             # Monitor devices for changes.\n"
msgstr "             # Наблюдение на устройствата за промени.\n"

#: tools/solid-hardware/solid-hardware.cpp:280
msgctxt "solid-hardware|"
msgid ""
"             # Send \"CanCheck\" request to the device corresponding to "
"'udi'.\n"
msgstr ""
"             # Изпращане на заявка \"CanCheck\"към устройството, отговарящо "
"на 'udi'.\n"

#: tools/solid-hardware/solid-hardware.cpp:283
